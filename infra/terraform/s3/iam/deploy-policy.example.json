{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ManageSpecificBucketConfiguration",
      "Effect": "Allow",
      "Action": [
        "s3:Get*",
        "s3:ListBucket",
        "s3:GetBucketTagging",
        "s3:PutBucketTagging",
        "s3:DeleteBucketTagging",
        "s3:GetBucketPublicAccessBlock",
        "s3:PutBucketPublicAccessBlock",
        "s3:GetBucketOwnershipControls",
        "s3:PutBucketOwnershipControls",
        "s3:GetBucketVersioning",
        "s3:PutBucketVersioning",
        "s3:GetEncryptionConfiguration",
        "s3:PutEncryptionConfiguration",
        "s3:GetBucketCors",
        "s3:PutBucketCors",
        "s3:DeleteBucketCors"
      ],
      "Resource": "arn:aws:s3:::sangue-doce"
    },
    {
      "Sid": "ManageObjectsInsideSpecificBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::sangue-doce/*"
    }
  ]
}
