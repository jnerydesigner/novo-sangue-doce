generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DiabetesType {
  TYPE_1
  TYPE_2
  GESTATIONAL
  OTHER
  UNKNOWN
}

enum Role {
  ADMIN
  USER
}

enum ReadingContext {
  FASTING
  BEFORE_MEAL
  AFTER_MEAL
  BEDTIME
  EXERCISE
  MANUAL
  RANDOM
}

enum MeasurementSource {
  MANUAL
  SENSOR
  IMPORT
}

enum MeasurementNoteType {
  FASTING_WAKE_UP
  BEFORE_BREAKFAST
  AFTER_BREAKFAST
  MORNING_RANDOM_CHECK
  BEFORE_LUNCH
  AFTER_LUNCH
  AFTERNOON_RANDOM_CHECK
  BEFORE_DINNER
  AFTER_DINNER
  BEFORE_SLEEP
  NIGHT_RANDOM_CHECK
  BEFORE_EXERCISE
  AFTER_EXERCISE
  FEELING_UNWELL
  ROUTINE_CHECK
  DAWN_RANDOM_CHECK
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostAccentColor {
  GREEN
  TOMATO
  BLUE
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  avatarUrl    String?       @map("avatar_url")
  birthDate    DateTime?     @map("birth_date")
  diabetesType DiabetesType  @default(UNKNOWN) @map("diabetes_type")
  role         Role          @default(USER)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  measurements Measurement[]
  postAuthors  PostAuthor[]

  @@map("users")
}

model Measurement {
  id               String               @id @default(uuid()) @db.Uuid
  userId           String               @map("user_id") @db.Uuid
  measuredAt       DateTime             @map("measured_at")
  glucoseValueMgDl Int                  @map("glucose_value_mg_dl")
  readingContext   ReadingContext       @default(MANUAL) @map("reading_context")
  source           MeasurementSource    @default(MANUAL)
  noteType         MeasurementNoteType? @map("note_type")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, measuredAt(sort: Desc)])
  @@map("measurements")
}

model PostAuthor {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  role      String
  bio       String?  @db.Text
  email     String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  posts     Post[]
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_authors")
}

model PostCategory {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  slug      String          @unique
  color     PostAccentColor @default(GREEN)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  posts     Post[]

  @@map("post_categories")
}

model PostTag {
  id        String            @id @default(uuid()) @db.Uuid
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  posts     PostTagRelation[]

  @@map("post_tags")
}

model PostTagRelation {
  postId String  @map("post_id") @db.Uuid
  tagId  String  @map("tag_id") @db.Uuid
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tag_relations")
}

model Post {
  id               String            @id @default(uuid()) @db.Uuid
  slug             String            @unique
  title            String
  excerpt          String            @db.Text
  standfirst       String?           @db.Text
  content          Json              @default("[]")
  status           PostStatus        @default(DRAFT)
  featured         Boolean           @default(false)
  readingMinutes   Int               @default(5) @map("reading_minutes")
  coverImageUrl    String?           @map("cover_image_url")
  coverImageAlt    String?           @map("cover_image_alt")
  coverCaption     String?           @map("cover_caption") @db.Text
  verticalImageUrl String?           @map("vertical_image_url")
  metaTitle        String?           @map("meta_title")
  metaDescription  String?           @map("meta_description") @db.Text
  publishedAt      DateTime?         @map("published_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  authorId         String            @map("author_id") @db.Uuid
  categoryId       String            @map("category_id") @db.Uuid
  author           PostAuthor        @relation(fields: [authorId], references: [id])
  category         PostCategory      @relation(fields: [categoryId], references: [id])
  tags             PostTagRelation[]
  postImages       PostImages[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([featured, publishedAt(sort: Desc)])
  @@index([categoryId, publishedAt(sort: Desc)])
  @@index([authorId])
  @@map("posts")
}

model PostImages {
  id          String   @id @default(uuid()) @db.Uuid
  postId      String   @unique @map("post_id") @db.Uuid
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  imageUrl    String
  imageAlt    String?
  imageLegend String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("post_images")
}

model EmailLoginCode {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email, createdAt(sort: Desc)])
  @@map("email_login_codes")
}
