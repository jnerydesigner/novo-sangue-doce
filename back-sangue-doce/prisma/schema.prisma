generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DiabetesType {
  TYPE_1
  TYPE_2
  GESTATIONAL
  OTHER
  UNKNOWN
}

enum Role {
  ADMIN
  USER
}

enum ReadingContext {
  FASTING
  BEFORE_MEAL
  AFTER_MEAL
  BEDTIME
  EXERCISE
  MANUAL
  RANDOM
}

enum MeasurementSource {
  MANUAL
  SENSOR
  IMPORT
}

enum MeasurementNoteType {
  FASTING_WAKE_UP
  BEFORE_BREAKFAST
  AFTER_BREAKFAST
  MORNING_RANDOM_CHECK
  BEFORE_LUNCH
  AFTER_LUNCH
  AFTERNOON_RANDOM_CHECK
  BEFORE_DINNER
  AFTER_DINNER
  BEFORE_SLEEP
  NIGHT_RANDOM_CHECK
  BEFORE_EXERCISE
  AFTER_EXERCISE
  FEELING_UNWELL
  ROUTINE_CHECK
  DAWN_RANDOM_CHECK
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PostAccentColor {
  GREEN
  TOMATO
  BLUE
}

enum RecipeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NewsletterSubscriberStatus {
  PENDING
  CONFIRMED
  UNSUBSCRIBED
  BOUNCED
  BLOCKED
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  email         String         @unique
  passwordHash  String         @map("password_hash")
  avatarUrl     String?        @map("avatar_url")
  birthDate     DateTime?      @map("birth_date")
  diabetesType  DiabetesType   @default(UNKNOWN) @map("diabetes_type")
  role          Role           @default(USER)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  carbAnalyses  CarbAnalysis[]
  measurements  Measurement[]
  postAuthors   PostAuthor[]
  recipeAuthors RecipeAuthor[]

  @@map("users")
}

model CarbAnalysis {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  imageUrl         String?  @map("image_url")
  result           Json
  estimatedGlucose Int?     @map("estimated_glucose")
  totalCarbsGrams  Int?     @map("total_carbs_grams")
  confidence       String?
  queueJobId       String?  @unique @map("queue_job_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("carb_analyses")
}

model Measurement {
  id               String               @id @default(uuid()) @db.Uuid
  userId           String               @map("user_id") @db.Uuid
  measuredAt       DateTime             @map("measured_at")
  glucoseValueMgDl Int                  @map("glucose_value_mg_dl")
  readingContext   ReadingContext       @default(MANUAL) @map("reading_context")
  source           MeasurementSource    @default(MANUAL)
  noteType         MeasurementNoteType? @map("note_type")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, measuredAt(sort: Desc)])
  @@map("measurements")
}

model PostAuthor {
  id          String                  @id @default(uuid()) @db.Uuid
  name        String
  slug        String                  @unique
  role        String
  bio         String?                 @db.Text
  email       String?                 @unique
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  posts       Post[]
  socialMedia PostAuthorSocialMedia[]
  userId      String                  @map("user_id") @db.Uuid
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("post_authors")
}

model PostAuthorSocialMedia {
  id        String     @id @default(uuid()) @db.Uuid
  authorId  String     @map("author_id") @db.Uuid
  name      String     @map("nome_rede_social")
  slug      String     @map("slug_rede_social")
  url       String
  position  Int        @default(0)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  author    PostAuthor @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([authorId, slug])
  @@index([authorId, position])
  @@map("post_author_social_media")
}

model PostCategory {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  slug      String          @unique
  color     PostAccentColor @default(GREEN)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  posts     Post[]

  @@map("post_categories")
}

model PostTag {
  id        String            @id @default(uuid()) @db.Uuid
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  posts     PostTagRelation[]

  @@map("post_tags")
}

model PostTagRelation {
  postId String  @map("post_id") @db.Uuid
  tagId  String  @map("tag_id") @db.Uuid
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tag_relations")
}

model Post {
  id                 String              @id @default(uuid()) @db.Uuid
  slug               String              @unique
  title              String
  excerpt            String              @db.Text
  standfirst         String?             @db.Text
  content            Json                @default("[]")
  status             PostStatus          @default(DRAFT)
  featured           Boolean             @default(false)
  readingMinutes     Int                 @default(5) @map("reading_minutes")
  coverImageUrl      String?             @map("cover_image_url")
  coverImageAlt      String?             @map("cover_image_alt")
  coverCaption       String?             @map("cover_caption") @db.Text
  verticalImageUrl   String?             @map("vertical_image_url")
  metaTitle          String?             @map("meta_title")
  metaDescription    String?             @map("meta_description") @db.Text
  publishedAt        DateTime?           @map("published_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  authorId           String              @map("author_id") @db.Uuid
  categoryId         String              @map("category_id") @db.Uuid
  author             PostAuthor          @relation(fields: [authorId], references: [id])
  category           PostCategory        @relation(fields: [categoryId], references: [id])
  tags               PostTagRelation[]
  postImages         PostImages[]
  socialPublications SocialPublication[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([featured, publishedAt(sort: Desc)])
  @@index([categoryId, publishedAt(sort: Desc)])
  @@index([authorId])
  @@map("posts")
}

model Recipe {
  id                 String              @id @default(uuid()) @db.Uuid
  slug               String              @unique
  title              String
  excerpt            String              @db.Text
  content            Json                @default("[]")
  status             RecipeStatus        @default(DRAFT)
  featured           Boolean             @default(false)
  readingMinutes     Int                 @default(5) @map("reading_minutes")
  coverImageUrl      String?             @map("cover_image_url")
  coverImageAlt      String?             @map("cover_image_alt")
  metaTitle          String?             @map("meta_title")
  metaDescription    String?             @map("meta_description") @db.Text
  publishedAt        DateTime?           @map("published_at")
  prepMinutes        Int                 @map("prep_minutes")
  cookMinutes        Int                 @default(0) @map("cook_minutes")
  servings           Int
  servingSize        String?             @map("serving_size")
  difficulty         RecipeDifficulty    @default(EASY)
  ingredients        Json
  instructions       Json
  caloriesKcal       Decimal?            @map("calories_kcal") @db.Decimal(8, 2)
  carbohydratesGrams Decimal?            @map("carbohydrates_grams") @db.Decimal(8, 2)
  fiberGrams         Decimal?            @map("fiber_grams") @db.Decimal(8, 2)
  proteinGrams       Decimal?            @map("protein_grams") @db.Decimal(8, 2)
  fatGrams           Decimal?            @map("fat_grams") @db.Decimal(8, 2)
  sodiumMg           Decimal?            @map("sodium_mg") @db.Decimal(8, 2)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  authorId           String              @map("author_id") @db.Uuid
  categoryId         String              @map("category_id") @db.Uuid
  author             RecipeAuthor        @relation(fields: [authorId], references: [id])
  category           RecipeCategory      @relation(fields: [categoryId], references: [id])
  tags               RecipeTagRelation[]

  @@index([difficulty])
  @@index([status, publishedAt(sort: Desc)])
  @@index([categoryId, publishedAt(sort: Desc)])
  @@index([authorId])
  @@map("recipes")
}

model RecipeAuthor {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  role      String
  bio       String?  @db.Text
  email     String?  @unique
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipes   Recipe[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("recipe_authors")
}

model RecipeCategory {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  slug      String          @unique
  color     PostAccentColor @default(GREEN)
  recipes   Recipe[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("recipe_categories")
}

model RecipeTag {
  id        String              @id @default(uuid()) @db.Uuid
  name      String
  slug      String              @unique
  recipes   RecipeTagRelation[]
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@map("recipe_tags")
}

model RecipeTagRelation {
  recipeId String    @map("recipe_id") @db.Uuid
  tagId    String    @map("tag_id") @db.Uuid
  recipe   Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      RecipeTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
  @@index([tagId])
  @@map("recipe_tag_relations")
}

enum SocialPublicationStatus {
  PENDING
  QUEUED
  PROCESSING
  GENERATING_TEXT
  GENERATING_IMAGE
  CONVERTING_IMAGE
  UPLOADING_IMAGE
  COMPLETED
  FAILED
  CANCELLED
  STANDBY
}

enum SocialPublicationGenerationMode {
  NEW_PUBLICATION
  REGENERATE_TEXT
  REGENERATE_IMAGE
}

model SocialPublication {
  id                   String                          @id @default(uuid()) @db.Uuid
  postId               String                          @db.Uuid
  status               SocialPublicationStatus         @default(PENDING)
  generationMode       SocialPublicationGenerationMode @default(NEW_PUBLICATION) @map("generation_mode")
  parentPublicationId  String?                         @map("parent_publication_id") @db.Uuid
  imageEditInstruction String?                         @map("image_edit_instruction") @db.VarChar(500)
  articleUrl           String?                         @map("article_url")

  generatedContent    String? @map("generated_content") @db.Text
  generatedHashtags   Json?   @map("generated_hashtags")
  generatedShortTitle String? @map("generated_short_title")
  generatedImageKey   String? @map("generated_image_key")
  generatedImageUrl   String? @map("generated_image_url")
  socialNetworks      Json    @default("[]") @map("social_networks")
  publicationResults  Json    @default("{}") @map("publication_results")
  scheduledPublishAt  DateTime? @map("scheduled_publish_at")
  scheduledSocialNetworks Json @default("[]") @map("scheduled_social_networks")
  scheduledPublishJobId String? @unique @map("scheduled_publish_job_id")
  scheduledBy String? @map("scheduled_by") @db.Uuid

  sourceImageKey String? @map("source_image_key")
  queueJobId     String? @unique @map("queue_job_id")
  correlationId  String  @unique @map("correlation_id")
  idempotencyKey String  @unique @map("idempotency_key")

  textModel     String? @map("text_model")
  imageModel    String? @map("image_model")
  promptVersion String? @map("prompt_version")
  attemptCount  Int     @default(0) @map("attempt_count")

  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message") @db.Text
  errorDetails Json?   @map("error_details")

  processingMetadata Json? @map("processing_metadata")

  requestedBy String? @map("requested_by") @db.Uuid

  queuedAt    DateTime? @map("queued_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  failedAt    DateTime? @map("failed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post                Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentPublication   SocialPublication?  @relation("SocialPublicationVersions", fields: [parentPublicationId], references: [id], onDelete: SetNull)
  derivedPublications SocialPublication[] @relation("SocialPublicationVersions")

  @@index([postId])
  @@index([parentPublicationId])
  @@index([status])
  @@index([scheduledPublishAt])
  @@index([createdAt])
  @@map("social_publications")
}

model InstitutionalPublication {
  id                 String    @id @default(uuid()) @db.Uuid
  title              String    @db.VarChar(180)
  content            String    @db.Text
  hashtags           Json      @default("[]")
  imageKey           String    @map("image_key")
  imageUrl           String    @map("image_url")
  publicationResults Json      @default("{}") @map("publication_results")
  requestedBy        String?   @map("requested_by") @db.Uuid
  publishedAt        DateTime? @map("published_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("institutional_publications")
}

model PostImages {
  id          String   @id @default(uuid()) @db.Uuid
  postId      String   @unique @map("post_id") @db.Uuid
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  imageUrl    String
  imageAlt    String?
  imageLegend String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("post_images")
}

model EmailLoginCode {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([email, createdAt(sort: Desc)])
  @@map("email_login_codes")
}

model NewsletterSubscriber {
  id                 String                     @id @default(uuid()) @db.Uuid
  email              String                     @unique
  normalizedEmail    String                     @unique
  name               String?
  status             NewsletterSubscriberStatus @default(PENDING)
  confirmationHash   String?
  confirmationExpiry DateTime?
  unsubscribeHash    String?
  source             String?
  confirmedAt        DateTime?
  unsubscribedAt     DateTime?
  bouncedAt          DateTime?
  blockedAt          DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("newsletter_subscribers")
}
